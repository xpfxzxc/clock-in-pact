DATABASE_URL="postgresql://postgres:123456@localhost:5432/clockinpact"

# 文件存储
STORAGE_TYPE="" # 留空时：production 自动用 cos，其余环境自动用 local。也可显式填 local 或 cos
COS_SECRET_ID=""
COS_SECRET_KEY=""
COS_BUCKET="" # 例如：clock-in-pact-1250000000（需包含 APPID）
COS_REGION="" # 例如：ap-shanghai
COS_SIGNED_URL_EXPIRES_IN_SECONDS="900" # 可选，私有桶签名 URL 过期时间（秒）

# 认证 (至少32位随机字符串)
NUXT_SESSION_PASSWORD=""
